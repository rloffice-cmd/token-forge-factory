# Telegram Bot Token - get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token

# Your Telegram Chat ID - send /start to @userinfobot to get yours
OWNER_CHAT_ID=your_chat_id

# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/memory_bot
# Railway: provided automatically
DATABASE_URL=postgresql://user:password@localhost:5432/memory_bot

# Google Gemini API Key (free) - get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Environment
NODE_ENV=development
